@page "/questions"
@inject TeaserStore Store

<PageTitle>One a Day — All questions</PageTitle>

<div class="oad-questions">
    <div class="oad-banner">All Questions</div>

    <label class="oad-search-label" for="search">Search Bar:</label>
    <input id="search" class="oad-search" type="search"
           placeholder="Search past questions..."
           @bind="_searchTerm" @bind:event="oninput" />

    <div class="oad-box">
        @if (Results.Count == 0)
        {
            <p>No questions found.</p>
        }
        else
        {
            <ol class="oad-question-list" reversed>
                @foreach (var teaser in Results)
                {
                    <li @key="teaser.Id">
                        @if (teaser.Date < _today)
                        {
                            <a class="oad-q-link" href="questions/@teaser.Date.ToString("yyyy-MM-dd")">
                                <span class="oad-q-date">@teaser.Date.ToString("ddd d MMM yyyy")</span>
                                <span class="oad-q-text">@teaser.Question</span>
                            </a>
                        }
                        else
                        {
                            <a class="oad-q-link" href="/">
                                <span class="oad-q-date">@teaser.Date.ToString("ddd d MMM yyyy") · Today's challenge</span>
                                <span class="oad-q-text">@teaser.Question</span>
                            </a>
                        }
                    </li>
                }
            </ol>
        }
    </div>
</div>

@code {
    private string _searchTerm = string.Empty;
    private DateOnly _today;

    private IReadOnlyList<BrainTeaser> Results => Store.Search(_searchTerm, _today);

    protected override void OnInitialized()
    {
        _today = AppTime.Today;
    }
}
