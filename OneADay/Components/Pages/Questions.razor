@page "/questions"
@inject TeaserStore Store

<PageTitle>One a Day — All questions</PageTitle>

<div class="oad-questions">
    <div class="oad-banner">All Questions</div>

    <label class="oad-search-label" for="search">Search Bar:</label>
    <input id="search" class="oad-search" type="search"
           placeholder="Search questions..."
           @bind="_searchTerm" @bind:event="oninput" />

    <div class="oad-box">
        @if (Results.Count == 0)
        {
            <p>No questions found.</p>
        }
        else
        {
            <ol class="oad-question-list" reversed>
                @foreach (var teaser in Results)
                {
                    var isToday = teaser.Date == _today;
                    var isUpcoming = teaser.Date > _today;
                    var href = isToday ? "/" : $"questions/{teaser.Date:yyyy-MM-dd}";
                    var suffix = isToday ? " · Today's challenge" : isUpcoming ? " · Scheduled" : "";
                    <li @key="teaser.Id">
                        <a class="oad-q-link" href="@href">
                            <span class="oad-q-date">
                                <span class="oad-q-datetext">@teaser.Date.ToString("ddd d MMM yyyy")@suffix</span>
                                <DifficultyBadge Level="teaser.Difficulty" />
                                @if (!string.IsNullOrWhiteSpace(teaser.ImageFileName))
                                {
                                    <span class="oad-q-imageicon" title="Includes an image">🖼️</span>
                                }
                            </span>
                            <span class="oad-q-text">@teaser.Question</span>
                        </a>
                    </li>
                }
            </ol>
        }
    </div>
</div>

@code {
    private string _searchTerm = string.Empty;
    private DateOnly _today;

    private IReadOnlyList<BrainTeaser> Results => Store.Search(_searchTerm);

    protected override void OnInitialized()
    {
        _today = AppTime.Today;
    }
}
