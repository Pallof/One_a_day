@page "/admin"
@inject TeaserStore Store
@inject StatsStore Stats
@inject SuggestionStore Suggestions
@inject ImageStore Images

<PageTitle>One a Day — Add a teaser</PageTitle>

<div class="oad-admin">
    <div class="oad-banner">@(_editingId is null ? "Add a brain teaser" : "Edit brain teaser")</div>

    <div class="oad-box">
        <div class="oad-field">
            <label for="date">Show on date</label>
            <InputDate id="date" @bind-Value="_form.Date" />
            @if (_dateWarning is not null)
            {
                <span class="oad-warning">@_dateWarning</span>
            }
        </div>

        <div class="oad-field">
            <label for="difficulty">Difficulty</label>
            <div class="oad-difficulty-row">
                <InputSelect id="difficulty" @bind-Value="_form.Difficulty">
                    <option value="@Difficulty.Easy">Easy</option>
                    <option value="@Difficulty.Medium">Medium</option>
                    <option value="@Difficulty.Hard">Hard</option>
                </InputSelect>
                <DifficultyBadge Level="_form.Difficulty" />
            </div>
        </div>

        <div class="oad-field">
            <label for="question">Question *</label>
            <textarea id="question" rows="4" placeholder="The brain teaser itself..."
                      @bind="_form.Question"></textarea>
        </div>

        <div class="oad-field">
            <label for="answer">Answer *</label>
            <input id="answer" placeholder="Accepted answer — separate alternatives with ; (e.g. 9; nine)"
                   @bind="_form.Answer" />
        </div>

        <div class="oad-field">
            <label for="tags">Tags (optional)</label>
            <input id="tags" placeholder="Comma-separated labels, e.g. logic, wordplay, math" @bind="_tagsText" @bind:event="oninput" />
            @if (ParsedTags.Count > 0)
            {
                <div class="oad-tag-preview">
                    @foreach (var tag in ParsedTags)
                    {
                        <span class="oad-tag-chip">@tag</span>
                    }
                </div>
            }
        </div>

        <div class="oad-field">
            <label for="image">Support image (optional)</label>
            <InputFile id="image" OnChange="OnImageSelected" accept="image/png,image/jpeg,image/gif,image/webp" />
            @if (_imageError is not null)
            {
                <span class="oad-warning">@_imageError</span>
            }
            @if (!string.IsNullOrWhiteSpace(_form.ImageFileName))
            {
                <div class="oad-image-preview">
                    <img src="@($"{ImageStore.RequestPath}/{_form.ImageFileName}")" alt="Selected support image" />
                    <button type="button" class="oad-btn-danger" @onclick="RemoveImage">Remove image</button>
                </div>
            }
        </div>

        <div class="oad-field">
            <label for="hint">Hint (optional)</label>
            <input id="hint" placeholder="Concealed on the home page until the solver clicks to reveal it" @bind="_form.Hint" />
        </div>

        <div class="oad-field">
            <label for="solution">Solution / explanation (optional)</label>
            <textarea id="solution" rows="3" placeholder="Explanation revealed once solved or on past questions"
                      @bind="_form.Solution"></textarea>
        </div>

        <div class="oad-admin-actions">
            <button class="oad-btn-green" @onclick="SaveAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_form.Question) || string.IsNullOrWhiteSpace(_form.Answer))">
                @(_editingId is null ? "Add teaser" : "Save changes")
            </button>
            @if (_editingId is not null)
            {
                <button class="oad-btn-plain" @onclick="() => ResetForm()">Cancel edit</button>
            }
        </div>

        @if (_savedMessage is not null)
        {
            <p class="oad-saved">@_savedMessage</p>
        }
    </div>

    <div class="oad-banner">Scheduled &amp; past teasers</div>

    <div class="oad-box">
        @if (_all.Count == 0)
        {
            <p>No teasers yet — add your first one above.</p>
        }
        else
        {
            <table class="oad-admin-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Difficulty</th>
                        <th>Question</th>
                        <th>Tags</th>
                        <th>Answer</th>
                        <th>Stats</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teaser in _all)
                    {
                        <tr class="@(teaser.Date == _today ? "oad-row-today" : teaser.Date > _today ? "oad-row-future" : "")">
                            <td class="oad-cell-date">@teaser.Date.ToString("ddd d MMM yyyy")</td>
                            <td><DifficultyBadge Level="teaser.Difficulty" /></td>
                            <td>@Truncate(teaser.Question, 80)</td>
                            <td class="oad-cell-tags">
                                @if (teaser.Tags.Count > 0)
                                {
                                    @foreach (var tag in teaser.Tags)
                                    {
                                        <span class="oad-tag-chip">@tag</span>
                                    }
                                }
                                else
                                {
                                    <span class="oad-cell-muted">—</span>
                                }
                            </td>
                            <td>@Truncate(teaser.Answer, 30)</td>
                            <td class="oad-cell-stats">@StatsSummary(teaser.Id)</td>
                            <td class="oad-cell-actions">
                                <button class="oad-btn-plain" @onclick="() => Edit(teaser)">Edit</button>
                                <button class="oad-btn-danger" @onclick="() => Delete(teaser.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="oad-banner">Visitor suggestions</div>

    <div class="oad-box">
        @if (_suggestions.Count == 0)
        {
            <p>No suggestions yet — they'll appear here when visitors submit one on the Contact us page.</p>
        }
        else
        {
            @foreach (var suggestion in _suggestions)
            {
                <div class="oad-suggestion" @key="suggestion.Id">
                    <div class="oad-suggestion-meta">
                        <span class="oad-suggestion-difficulty">@suggestion.Difficulty</span>
                        <span>@suggestion.SubmittedAt.ToString("d MMM yyyy, h:mm tt") PT</span>
                    </div>
                    <p class="oad-suggestion-q">@suggestion.Question</p>
                    <p class="oad-suggestion-s"><strong>Solution + hint:</strong> @suggestion.SolutionAndHint</p>
                    <div class="oad-suggestion-actions">
                        <button class="oad-btn-plain" @onclick="() => UseSuggestion(suggestion)">Use in form above</button>
                        <button class="oad-btn-danger" @onclick="() => DeleteSuggestion(suggestion.Id)">Delete</button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private BrainTeaser _form = new();
    private Guid? _editingId;
    private string? _savedMessage;
    private string? _dateWarning;
    private string _tagsText = string.Empty;
    private string? _imageError;
    private string? _originalImageName;   // image the teaser had when Edit was opened
    private DateOnly _today;
    private IReadOnlyList<BrainTeaser> _all = [];
    private IReadOnlyList<TeaserSuggestion> _suggestions = [];

    private List<string> ParsedTags => _tagsText
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override void OnInitialized()
    {
        _today = AppTime.Today;
        ResetForm();
        Refresh();
    }

    private void Refresh()
    {
        _all = Store.GetAll();
        _suggestions = Suggestions.GetAll();
    }

    private void ResetForm(bool discardStaged = true)
    {
        if (discardStaged)
        {
            DiscardStagedImage();
        }
        _editingId = null;
        _originalImageName = null;
        _tagsText = string.Empty;
        _imageError = null;
        // Default to the first upcoming day that doesn't have a teaser yet.
        var date = _today;
        while (Store.GetForDate(date) is not null)
        {
            date = date.AddDays(1);
        }
        _form = new BrainTeaser { Date = date };
        _dateWarning = null;
    }

    private void Edit(BrainTeaser teaser)
    {
        DiscardStagedImage();   // drop an un-saved upload from any in-progress form
        _editingId = teaser.Id;
        _originalImageName = teaser.ImageFileName;
        _tagsText = string.Join(", ", teaser.Tags);
        _form = new BrainTeaser
        {
            Id = teaser.Id,
            Date = teaser.Date,
            Difficulty = teaser.Difficulty,
            Tags = new List<string>(teaser.Tags),
            ImageFileName = teaser.ImageFileName,
            Question = teaser.Question,
            Answer = teaser.Answer,
            Hint = teaser.Hint,
            Solution = teaser.Solution,
        };
        _savedMessage = null;
        _dateWarning = null;
        _imageError = null;
    }

    private Task SaveAsync()
    {
        var existing = Store.GetForDate(_form.Date);
        if (existing is not null && existing.Id != _form.Id)
        {
            _dateWarning = $"There is already a teaser on {_form.Date:d MMM yyyy}. Pick another date or edit that one below.";
            return Task.CompletedTask;
        }

        _form.Tags = ParsedTags;
        Store.Save(_form);

        // Original image was replaced or removed during this edit → clean it up.
        if (_originalImageName is not null && _originalImageName != _form.ImageFileName)
        {
            Images.Delete(_originalImageName);
        }

        _savedMessage = $"Saved! \"{Truncate(_form.Question, 50)}\" will show on {_form.Date:dddd d MMMM yyyy}.";
        ResetForm(discardStaged: false);   // the image just saved is now committed
        Refresh();
        return Task.CompletedTask;
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!ImageStore.IsAllowedType(file.ContentType))
        {
            _imageError = "Please choose a PNG, JPG, GIF, or WebP image.";
            return;
        }
        if (file.Size > ImageStore.MaxBytes)
        {
            _imageError = "Image must be under 3 MB.";
            return;
        }
        _imageError = null;
        DiscardStagedImage();   // replacing a previous un-saved upload
        _form.ImageFileName = await Images.SaveAsync(file);
    }

    private void RemoveImage()
    {
        DiscardStagedImage();
        _form.ImageFileName = null;
        _imageError = null;
    }

    /// <summary>Deletes a just-uploaded image that hasn't been committed to a saved teaser.</summary>
    private void DiscardStagedImage()
    {
        if (_form.ImageFileName is not null && _form.ImageFileName != _originalImageName)
        {
            Images.Delete(_form.ImageFileName);
        }
    }

    private string StatsSummary(Guid teaserId)
    {
        var stats = Stats.Get(teaserId);
        return stats.TotalSubmissions == 0
            ? "—"
            : $"{stats.UniqueAttempters:N0} {(stats.UniqueAttempters == 1 ? "mind" : "minds")} · {stats.SuccessfulSubmissions:N0}/{stats.TotalSubmissions:N0} successful";
    }

    private void Delete(Guid id)
    {
        var teaser = _all.FirstOrDefault(t => t.Id == id);
        Images.Delete(teaser?.ImageFileName);
        Store.Delete(id);
        Stats.Remove(id);
        if (_editingId == id)
        {
            ResetForm();
        }
        Refresh();
    }

    private void UseSuggestion(TeaserSuggestion suggestion)
    {
        // Pre-fill the add form; the solution+hint lands in Solution for
        // manual splitting into Answer/Hint/Solution before saving.
        DiscardStagedImage();
        _editingId = null;
        _originalImageName = null;
        _tagsText = string.Empty;
        _imageError = null;
        var date = _today;
        while (Store.GetForDate(date) is not null)
        {
            date = date.AddDays(1);
        }
        _form = new BrainTeaser
        {
            Date = date,
            Difficulty = Enum.TryParse<Difficulty>(suggestion.Difficulty, out var d) ? d : Difficulty.Medium,
            Question = suggestion.Question,
            Solution = suggestion.SolutionAndHint,
        };
        _savedMessage = null;
        _dateWarning = null;
    }

    private void DeleteSuggestion(Guid id)
    {
        Suggestions.Delete(id);
        Refresh();
    }

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "…";
}
