@page "/"
@inject TeaserStore Store

<PageTitle>One a Day — Challenge of the day</PageTitle>

<div class="oad-home">
    <div class="oad-banner">Challenge of the day</div>

    @if (_teaser is null)
    {
        <div class="oad-box">
            <h2>Question:</h2>
            <p>No brain teaser has been posted yet. Check back soon!</p>
        </div>
    }
    else
    {
        <ChallengeView Teaser="_teaser"
                       IsDaily="true"
                       CanReveal="@(_teaser.Date < _today)"
                       Note="@(_teaser.Date != _today ? $"From {_teaser.Date:dddd d MMMM yyyy} — today's teaser hasn't been posted yet." : null)" />
    }
</div>

@code {
    private BrainTeaser? _teaser;
    private DateOnly _today;

    protected override void OnInitialized()
    {
        _today = AppTime.Today;
        _teaser = Store.GetCurrent(_today);
    }
}
